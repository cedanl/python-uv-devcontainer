{
  "permissions": {
    "allow": [
      "Bash(uv init:*)",
      "Bash(uv add:*)",
      "Read(//tmp/**)",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(uv run:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh pr:*)",
      "Bash(git checkout:*)"
